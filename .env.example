# Copy this file to .env before running the production-style Compose stack.
# Change the password values before any real deployment or shared environment.

POSTGRES_DB=localdeploydb
POSTGRES_USER=localdeploy_user
POSTGRES_PASSWORD=localdeploy_password

DB_HOST=database
DB_PORT=5432
DB_NAME=localdeploydb
DB_USER=localdeploy_user
DB_PASSWORD=localdeploy_password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_SECONDS=60

ACTIVITY_SERVICE_URL=http://activity-service:8081

ASPNETCORE_ENVIRONMENT=Development

# Development Compose enables Swagger automatically.
# Uncomment only when you intentionally want Swagger in production-style mode.
# ENABLE_SWAGGER=true

# Used by docker-compose.prod.yml.
NGINX_HTTP_PORT=80
